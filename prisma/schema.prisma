generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  BRAND
  CREATOR
  ADMIN
}

enum Platform {
  INSTAGRAM
  TIKTOK
  TWITTER
  FACEBOOK
  YOUTUBE
}

enum ContentType {
  POST
  STORY
  REEL
  VIDEO
  THREAD
  LIVE
}

enum OrderStatus {
  PENDING               // Waiting for creator to accept
  ACCEPTED              // Creator accepted, awaiting payment
  IN_PROGRESS           // Payment held, creator is working
  REVISION_REQUESTED    // Brand requested changes
  COMPLETED             // Brand approved, payment released
  CANCELLED             // Cancelled before completion
  DISPUTED              // Under dispute resolution
}

enum PaymentStatus {
  PENDING     // Payment initiated but not yet confirmed
  HELD        // Escrow: funds held by platform
  RELEASED    // Released to creator upon approval
  REFUNDED    // Returned to brand (cancellation/dispute)
}

enum SubscriptionPlan {
  STARTER     // Free tier (3 campaigns/month)
  GROWTH      // Rp 299K/month — most popular
  ENTERPRISE  // Custom pricing
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
}

enum ReviewType {
  BRAND_TO_CREATOR
  CREATOR_TO_BRAND
}

// ─────────────────────────────────────────────
// USERS & PROFILES
// ─────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  phone      String?
  avatar     String?
  role       Role
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  creatorProfile CreatorProfile?
  brandProfile   BrandProfile?

  sentMessages      Message[]                 @relation("SentMessages")
  notifications     Notification[]
  reviewsGiven      Review[]                  @relation("ReviewsGiven")
  reviewsReceived   Review[]                  @relation("ReviewsReceived")
  conversations     ConversationParticipant[]

  @@map("users")
}

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  location        String?
  website         String?
  isAvailable     Boolean  @default(true)
  avgResponseTime Int?     // hours
  completionRate  Float    @default(100) // percentage
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccounts SocialMediaAccount[]
  niches         CreatorNiche[]
  packages       Package[]
  portfolioItems PortfolioItem[]
  orders         Order[]              @relation("CreatorOrders")

  @@map("creator_profiles")
}

model BrandProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  industry    String?
  website     String?
  description String?
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]
  orders       Order[]       @relation("BrandOrders")
  subscription Subscription?

  @@map("brand_profiles")
}

// ─────────────────────────────────────────────
// SOCIAL MEDIA & NICHES
// ─────────────────────────────────────────────

model SocialMediaAccount {
  id             String   @id @default(cuid())
  creatorId      String
  platform       Platform
  username       String
  profileUrl     String?
  followersCount Int      @default(0)
  engagementRate Float    @default(0) // percentage
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@map("social_media_accounts")
}

model Niche {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?

  creators  CreatorNiche[]
  campaigns CampaignNiche[]

  @@map("niches")
}

model CreatorNiche {
  creatorId String
  nicheId   String

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  niche   Niche          @relation(fields: [nicheId], references: [id], onDelete: Cascade)

  @@id([creatorId, nicheId])
  @@map("creator_niches")
}

// ─────────────────────────────────────────────
// PACKAGES (Creator's Service Offerings)
// ─────────────────────────────────────────────

model Package {
  id             String      @id @default(cuid())
  creatorId      String
  name           String
  description    String?
  platform       Platform
  contentType    ContentType
  price          Decimal     @db.Decimal(14, 2) // IDR
  deliveryDays   Int
  revisionsCount Int         @default(1)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@map("packages")
}

// ─────────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────────

model Campaign {
  id          String     @id @default(cuid())
  brandId     String
  title       String
  description String?
  platforms   Platform[] // Supported platforms for this campaign
  budget      Decimal    @db.Decimal(14, 2) // IDR
  startDate   DateTime?
  endDate     DateTime?
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  brand  BrandProfile    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  niches CampaignNiche[]
  orders Order[]

  @@map("campaigns")
}

model CampaignNiche {
  campaignId String
  nicheId    String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  niche    Niche    @relation(fields: [nicheId], references: [id], onDelete: Cascade)

  @@id([campaignId, nicheId])
  @@map("campaign_niches")
}

// ─────────────────────────────────────────────
// ORDERS & PAYMENTS
// ─────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  campaignId    String?
  packageId     String
  creatorId     String
  brandId       String
  brief         String      // What the brand needs
  requirements  String?     // Additional requirements / reference links
  status        OrderStatus @default(PENDING)
  totalAmount   Decimal     @db.Decimal(14, 2) // IDR — what brand pays
  platformFee   Decimal     @db.Decimal(14, 2) // 10% platform commission
  creatorAmount Decimal     @db.Decimal(14, 2) // Amount released to creator
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  campaign     Campaign?      @relation(fields: [campaignId], references: [id])
  package      Package        @relation(fields: [packageId], references: [id])
  creator      CreatorProfile @relation("CreatorOrders", fields: [creatorId], references: [id])
  brand        BrandProfile   @relation("BrandOrders", fields: [brandId], references: [id])
  payment      Payment?
  revisions    Revision[]
  reviews      Review[]
  conversation Conversation?

  @@map("orders")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  amount        Decimal       @db.Decimal(14, 2) // IDR
  status        PaymentStatus @default(PENDING)
  paymentMethod String?       // e.g. "bank_transfer", "virtual_account", "e-wallet"
  transactionId String?       @unique // External payment gateway ref
  paidAt        DateTime?     // When brand paid
  releasedAt    DateTime?     // When platform released to creator
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Revision {
  id          String    @id @default(cuid())
  orderId     String
  notes       String    // Feedback on what needs to change
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("revisions")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id         String     @id @default(cuid())
  orderId    String
  reviewerId String
  revieweeId String
  type       ReviewType
  rating     Int        // 1–5 stars
  comment    String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer User  @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User  @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  // One review per direction per order (brand→creator and creator→brand are separate)
  @@unique([orderId, type])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  orderId   String?  @unique // Linked to an order (optional — can pre-order chat)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order        Order?                    @relation(fields: [orderId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   // e.g. "order_accepted", "payment_released", "new_message"
  isRead    Boolean  @default(false)
  data      Json?    // Extra metadata (orderId, senderId, etc.)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS (Brand Plans)
// ─────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  brandId            String             @unique
  plan               SubscriptionPlan   @default(STARTER)
  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  brand BrandProfile @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// PORTFOLIO (Creator showcase items)
// ─────────────────────────────────────────────

model PortfolioItem {
  id             String    @id @default(cuid())
  creatorId      String
  platform       Platform
  title          String?
  url            String    // Link to the content
  thumbnail      String?
  description    String?
  likesCount     Int       @default(0)
  viewsCount     Int       @default(0)
  commentsCount  Int       @default(0)
  engagementRate Float     @default(0) // percentage
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("portfolio_items")
}
